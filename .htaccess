# ============================================================
# SME Finance Monitor — Apache Configuration
# ============================================================

Options -Indexes

# ---- Force HTTPS on production (uncomment when SSL is active) ----
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ---- PHP settings for shared hosting ----
<IfModule mod_php8.c>
    php_value upload_max_filesize 3M
    php_value post_max_size       4M
    php_value max_execution_time  60
    php_value memory_limit        128M
</IfModule>
<IfModule mod_php7.c>
    php_value upload_max_filesize 3M
    php_value post_max_size       4M
    php_value max_execution_time  60
    php_value memory_limit        128M
</IfModule>

# ---- Security headers ----
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ---- Block direct access to sensitive directories ----
RewriteEngine On
RewriteRule ^(app|config|controllers|models|views|lang|routes|database|storage)(/|$) - [F,L]

# ---- Block .env and other dot files ----
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# ---- Allow direct access to assets, uploads, and index.php ----
RewriteCond %{REQUEST_URI} ^/assets/   [OR]
RewriteCond %{REQUEST_URI} ^/uploads/
RewriteRule ^ - [L]

# ---- Send all other requests to index.php ----
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
